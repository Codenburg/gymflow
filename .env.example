# Environment variables for the Gym Routines application
DATABASE_URL="postgresql://gym_user:gym_password@localhost:5432/gym_routines?schema=public"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Better Auth Configuration
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-min-32-characters-here"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"
# Seed Script - Admin Passwords (used by prisma/seed.ts)
# Change these in .env for development
SEED_ADMIN_PASSWORD_1="nando123"
SEED_ADMIN_PASSWORD_2="leo123"
SEED_ADMIN_PASSWORD_3="santi123"
