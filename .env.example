# Environment variables for the Gym Routines application
DATABASE_URL="postgresql://gym_user:gym_password@localhost:5432/gym_routines?schema=public"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Gym display name (deploy-time identity for unauthenticated surfaces).
# The fallback chain is:
#   1. `Gym.nombre` from the database (set via /admin/config)
#   2. `NEXT_PUBLIC_GYM_NAME` (this variable)
#   3. Generic "Gimnasio" (last-resort, intentionally neutral)
#
# Leave empty in development so the chain falls through to step 3.
# Production deploys SHOULD set this to the deploying gym's name so
# the login page title and root metadata reflect the right identity.
NEXT_PUBLIC_GYM_NAME=""

# Better Auth Configuration
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-min-32-characters-here"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"
# Seed Script - Passwords (used by prisma/seed.ts)
# Change these in .env for development
SEED_ADMIN_PASSWORD_1="nando123"

# Seed Script - Trainer Passwords (used by prisma/seed.ts)
SEED_TRAINER_PASSWORD_1="leo123"
SEED_TRAINER_PASSWORD_2="santi123"
SEED_TRAINER_PASSWORD_3="facu123"
