// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model Rutina {
  id          String   @id @default(uuid())
  nombre      String
  tipo        String
  descripcion String?
  // Required FK to User.id - every routine must have a creator
  creadorId   String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  dias        Dia[]

  // Relation to User (creator) - RESTRICT: deletion blocked if user has rutinas
  // Transfer ownership before deleting a user with rutinas
  creadorUser User     @relation(fields: [creadorId], references: [id], onDelete: Restrict)

  // Ownership transfer history for this rutina
  ownershipTransfers OwnershipTransfer[]

  // Unique constraint: same user cannot have two routines with the same name
  @@unique([creadorId, nombre])
  @@index([creadorId])
}

model Dia {
  id                String     @id @default(uuid())
  rutinaId          String
  musculosEnfocados String[]
  orden             Int        @default(0)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  rutina            Rutina     @relation(fields: [rutinaId], references: [id], onDelete: Cascade)
  ejercicios        Ejercicio[]

  @@index([rutinaId])
}

model Ejercicio {
  id        String   @id @default(uuid())
  diaId     String
  nombre    String
  series    Int?
  repes     Int?
  orden     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dia       Dia      @relation(fields: [diaId], references: [id], onDelete: Cascade)

  @@index([diaId])
}

// ======================
// Better Auth Models
// ======================

model User {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  dni            String    @unique
  // Username para login con DNI (requerido por username plugin)
  username       String?   @unique
  // Email opcional
  email          String?   @unique
  emailVerified  Boolean   @default(false)
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  admin          Boolean   @default(false)
  role           String    @default("user")
  banned         Boolean   @default(false)
  // Soft delete timestamp - if set, user is considered deleted
  // All queries must filter: where: { deletedAt: null }
  deletedAt      DateTime? @db.Timestamp

  // Index for soft-delete query performance
  @@index([deletedAt])

  sessions       Session[]
  accounts       Account[]
  // Routines created by this user
  rutinas        Rutina[]
  // Ownership transfers where user was the source
  transfersFrom  OwnershipTransfer[] @relation("FromUser")
  // Ownership transfers where user was the target
  transfersTo    OwnershipTransfer[] @relation("ToUser")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @db.Uuid
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @db.Uuid
  accountId         String
  providerId        String
  providerType      String
  accessToken       String?
  refreshToken      String?
  idToken           String?
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope             String?
  password          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, providerType, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, value])
}

// ======================
// Ownership Transfer Audit
// ======================

model OwnershipTransfer {
  id        String   @id @default(uuid())
  rutinaId  String
  // null fromUserId means initial creation (not a transfer)
  fromUserId String? @db.Uuid
  toUserId  String   @db.Uuid
  createdAt DateTime @default(now())

  rutina    Rutina @relation(fields: [rutinaId], references: [id], onDelete: Cascade)
  fromUser  User?   @relation("FromUser", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUser    User   @relation("ToUser", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([rutinaId])
  @@index([fromUserId])
  @@index([toUserId])
}

// ======================
// Singleton Gym Config Model
// ======================

model Gym {
  id        String   @id @default("gym")
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  feriados  Feriado[]
  promociones Promocion[]
  descuentosDuracion DescuentoDuracion[]
}

// ======================
// Information Page Models
// ======================

model Feriado {
  id          String    @id @default(uuid())
  fecha       String    // Calendar date in YYYY-MM-DD format (NOT timestamp)
  todo_dia    Boolean   @default(true)
  hora_inicio String?
  hora_fin    String?
  createdAt   DateTime  @default(now())
  gymId       String    @default("gym")
  gym         Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([gymId, fecha])
  @@index([gymId])
}

model Promocion {
  id          String   @id @default(uuid())
  titulo      String
  descripcion String
  precio      String
  activo      Boolean  @default(true)
  gymId       String
  gym         Gym      @relation(fields: [gymId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DescuentoDuracion {
  id          Int      @id @default(autoincrement())
  meses       Int      // enum: 3, 6, 9, 12
  porcentaje  Int      // Int sin enum - valores libres
  gymId       String
  gym         Gym      @relation(fields: [gymId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([gymId, meses])
}
